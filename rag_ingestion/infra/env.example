# ──────────────────────────────────────────────────────────────────────────────
# Environment variables for the RAG ingestion pipeline.
# Copy this file to .env (or export the variables) before running the pipeline.
# ──────────────────────────────────────────────────────────────────────────────

# ── GCP Project / Region ───────────────────────────────────────────────────────
GCP_PROJECT=my-gcp-project
GCP_REGION=europe-west1

# ── GCS Input ─────────────────────────────────────────────────────────────────
# GCS prefix where source documents are stored (trailing slash required).
GCS_INPUT_PREFIX=gs://my-bucket/docs/

# Bucket used by Dataflow for staging/temp files.
DATAFLOW_STAGING_BUCKET=gs://my-bucket/dataflow-staging
DATAFLOW_TEMP_LOCATION=gs://my-bucket/dataflow-temp

# ── Vertex AI Embeddings ───────────────────────────────────────────────────────
# Model name as registered in Vertex AI.
# text-embedding-005 outputs 768-dimensional vectors.
# If you change this, also update EMBEDDING_DIM and re-run 001_init.sql.
EMBEDDING_MODEL=text-embedding-005
EMBEDDING_DIM=768
# Number of texts per Vertex AI API call (max recommended: 5).
EMBEDDING_BATCH_SIZE=5

# ── Chunking ───────────────────────────────────────────────────────────────────
# Maximum tokens per chunk (cl100k_base tokeniser, ~4 chars/token).
CHUNK_MAX_TOKENS=512
# Tokens to carry over as overlap between consecutive chunks.
CHUNK_OVERLAP_TOKENS=64

# ── CloudSQL / pgvector ────────────────────────────────────────────────────────
# For Dataflow workers connecting via Cloud SQL Auth Proxy or Private IP.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ragdb
DB_USER=raguser
DB_PASSWORD=changeme

# ── Service Account (optional — override ADC) ──────────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
